# Apple Code Signing & Notarization (macOS)
# Kopieer naar .env en vul in. Commit .env NOOIT.

# Je Apple ID (e-mail)
APPLE_ID=josklijnhout@hotmail.com

# App-specifiek wachtwoord (maak aan op https://appleid.apple.com → Sign-in and Security)
APPLE_APP_SPECIFIC_PASSWORD=Vrijheid@liefdeis#1

# Team ID (te vinden op https://developer.apple.com/account → Membership)
APPLE_TEAM_ID=G3N6YWNG5R

# Certificaatnaam ZONDER "Developer ID Application:" (electron-builder vult dat zelf in)
# Format: "Je Naam (TEAM_ID)"
CSC_NAME="jos Klijnhout (G3N6YWNG5R)"
